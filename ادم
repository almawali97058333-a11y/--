<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8" />
  <title>تسجيل الدخول</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f0f0f0;
      text-align: center;
      padding: 50px;
    }
    .login-box {
      background: white;
      padding: 20px;
      display: inline-block;
      border-radius: 10px;
      box-shadow: 0 0 10px #aaa;
    }
    input {
      padding: 10px;
      margin: 10px 0;
      width: 80%;
      font-size: 16px;
    }
    button {
      padding: 10px 20px;
      font-size: 16px;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <div class="login-box">
    <h2>تسجيل الدخول</h2>
    <input type="text" placeholder="اسم المستخدم" />
    <input type="password" placeholder="كلمة المرور" />
    <br />
    <button onclick="alert('هاها! هذه صفحة مزحة فقط 😊')">دخول</button>
  </div>
</body>
</html>
